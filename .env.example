# TerminalX MVP environment
TERMINALX_APP_NAME=TerminalX
TERMINALX_ENV=development
TERMINALX_HOST=127.0.0.1
TERMINALX_PORT=8787
AUTH_REQUIRED=true
SESSION_SECRET=
ADMIN_EMAIL=admin@terminalx.local
ADMIN_PASSWORD=change-me-now

# Runtime mode. ONLINE_MODE prepares TerminalX to use cloud APIs.
# OFFLINE_MODE keeps the foundation on local services and prepares future
# Ollama/local LLM integration.
TERMINALX_RUNTIME_MODE=ONLINE_MODE

# Database. Use DATABASE_PROVIDER=postgres with a Supabase/PostgreSQL
# connection string when the PostgreSQL driver is added. If PostgreSQL is not
# available, TerminalX falls back to local SQLite.
DATABASE_PROVIDER=sqlite
DATABASE_URL=
DATABASE_SSL=false
SQLITE_PATH=./storage/local/terminalx.db

# File storage provider. Use local for development, supabase for Supabase Storage,
# or s3 for S3-compatible storage such as AWS S3, Cloudflare R2, or MinIO.
# Use local for OFFLINE_MODE/laptop server mode.
FILE_STORAGE_PROVIDER=local
FILE_STORAGE_LOCAL_PATH=./storage/local/files

# Supabase Storage placeholders. Do not commit real secrets.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=terminalx-files

# S3-compatible placeholders. Do not commit real secrets.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# AI provider routing. LLM_PROVIDER can be auto, openai, anthropic, gemini, groq, ollama, or mock.
LLM_PROVIDER=auto
CLOUD_LLM_MODEL=
OPENAI_MODEL=gpt-5-mini
ANTHROPIC_MODEL=claude-sonnet-4-5
GEMINI_MODEL=gemini-2.0-flash
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Offline/local LLM placeholders. These are preparation only.
LOCAL_LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:latest
